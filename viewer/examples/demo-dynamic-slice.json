      "line_start": 53,
      "line_end": 79,
      "code_snippet": "always_ff @(posedge clk or negedge rst_n) begin\n        if (!rst_n) begin\n            result   <= 8'h0;\n            overflow <= 1'b0;\n        end else if (state == ST_EXEC) begin  // Line 56: exec branch\n            case (op)                         // Line 57: op case\n                2'b01: begin                  // Line 58: ADD\n                    tmp = {1'b0, a} + {1'b0, b};\n                    result   <= tmp[7:0];\n                    overflow <= tmp[8];\n                end\n                2'b10: begin                  // Line 63: SUB\n                    tmp = {1'b0, a} - {1'b0, b};\n                    result   <= tmp[7:0];\n                    overflow <= tmp[8];\n                end\n                2'b11: begin                  // Line 68: AND\n                    result   <= a & b;\n                    overflow <= 1'b0;\n                end\n                default: begin                // Line 72: default/NOP\n                    result   <= 8'h0;\n                    overflow <= 1'b0;\n                end\n            endcase\n        end\n    end"
    },
